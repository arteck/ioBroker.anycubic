{
  "name": "iobroker.anycubic",
  "version": "0.0.1",
  "description": "anycubic adapter for ioBroker",
  "author": {
    "name": "Arthur Rupp",
    "email": "arteck@outlook.com"
  },
  "homepage": "https://github.com/arteck/ioBroker.anycubic",
  "license": "MIT",
  "keywords": [
    "anycubic",
    "3d printer",
    "ioBroker",
    "template",
    "Smart Home",
    "home automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arteck/ioBroker.anycubic.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "@iobroker/dm-utils": "^3.0.19",
    "@iobroker/plugin-docker": "^1.0.3",
    "humanize-duration": "^3.33.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node-schedule": "^2.1.8",
    "chai-as-promised": "^8.0.2",
    "sinon-chai": "^4.0.1",
    "typescript": "~6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "io-package.json"
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/arteck/ioBroker.anycubic/issues"
  },
  "readmeFilename": "README.md"
}
