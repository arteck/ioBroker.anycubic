{
  "i18n": true,
  "type": "tabs",
  "tabsStyle": {
    "width": "calc(100% - 100px)"
  },
  "items": {
    "_deviceManager": {
      "type": "panel",
      "label": "devices",
      "items": {
        "_devMng": {
          "type": "deviceManager",
          "sm": 12,
          "style": {
            "width": "100%",
            "height": "100%",
            "overflow": "hidden"
          }
        }
      },
      "style": {
        "width": "100%",
        "height": "100%",
        "overflow": "hidden"
      },
      "innerStyle": {
        "width": "100%",
        "height": "100%",
        "overflow": "hidden"
      }
    },
    "_tab_Start": {
      "type": "panel",
      "label": "Main Settings",
      "items": {
        "header_Start": {
          "type": "header",
          "text": "anycubic adapter settings",
          "size": 2
        },
        "_textStart": {
          "type": "staticText",
          "text": "A detailed documentation with explanations and all further information can be found on this GitHub page",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "style": {
            "fontSize": 14,
            "marginTop": 0
          }
        },
        "_documentationLink": {
          "type": "staticLink",
          "label": "click for Documentation",
          "button": true,
          "href": "https://github.com/arteck/ioBroker.anycubic/blob/main/README.md",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "style": {
            "fontSize": 18,
            "marginTop": 0
          }
        },
        "connectionHeader": {
          "type": "header",
          "text": "Select and configure your anycubic connection",
          "size": 2,
          "newLine": true
        },
        "connectionType": {
          "label": "Connection type",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "type": "select",
          "options": [
            {
              "label": "Websocket",
              "value": "ws"
            }
          ],
          "newLine": true
        },
        "wsScheme": {
          "type": "select",
          "label": "Scheme",
          "options": [
            {
              "label": "WS",
              "value": "ws"
            },
            {
              "label": "WSS (SSL)",
              "value": "wss"
            }
          ],
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "wsServerIP": {
          "type": "text",
          "label": "Websocket IP-Address",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        },
        "wsServerPort": {
          "type": "number",
          "label": "Websocket Port",
          "newLine": false,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "wsTokenEnabled": {
          "type": "checkbox",
          "label": "Use Auth-Token",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "wsToken": {
          "type": "password",
          "label": "Auth-Token (special characters are not supported)",
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 5,
          "xl": 4,
          "hidden": "data.wsTokenEnabled != true"
        },
        "webUIHeader": {
          "type": "header",
          "text": "Configure your anycubic WebUi connection",
          "size": 2,
          "newLine": true
        },
        "webUIScheme": {
          "type": "select",
          "label": "Scheme",
          "options": [
            {
              "label": "HTTP",
              "value": "http"
            },
            {
              "label": "HTTPS",
              "value": "https"
            }
          ],
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": true
        },
        "webUIServer": {
          "type": "text",
          "label": "WebUi IP-Address",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        },
        "webUIPort": {
          "type": "number",
          "label": "WebUi Port",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        }
      }
    },
    "_tab_Other Settings": {
      "type": "panel",
      "label": "Other configurations",
      "items": {
        "wsOnStart": {
          "type": "checkbox",
          "label": "allow start send WS message directly after adapter start",
          "default": true,
          "help": "This allows you to decide whether messages are sent immediately after the adapter starts. If the checkbox is false, the last status is taken from the info.sendMessageAllowed DP.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "newLine": true
        },
        "showNodeInfoMessage": {
          "type": "checkbox",
          "label": "Show Node Info messages to ioBroker log",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "newLine": true
        },
        "useEventInDesc": {
          "type": "checkbox",
          "label": "The events such as 'Device removed' or 'Disabled' are displayed in the description instead of in the name",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "wakeUpInfo": {
          "type": "checkbox",
          "label": "Inform about wake up and sleep of battery devices in the log",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "newTypeEvent": {
          "type": "checkbox",
          "label": "new Type event Warning in log",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "spacerDeleteStates": {
          "type": "staticText",
          "text": "",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "newLine": true
        },
        "headerDeleteStates": {
          "type": "header",
          "text": "",
          "size": 4,
          "newLine": true
        },
        "buttonDeleteNullStates": {
          "type": "sendTo",
          "command": "deleteNullStates",
          "label": "Delete null states",
          "variant": "contained",
          "color": "secondary",
          "icon": "delete",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3,
          "newLine": true
        },
        "_deleteNullStatesResult": {
          "type": "staticText",
          "text": "",
           "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3,
          "newLine": false,
          "style": {
            "marginTop": 8,
            "fontStyle": "italic"
          }
        }
      }
    }
  }
}