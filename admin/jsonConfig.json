{
  "i18n": true,
  "type": "tabs",
  "tabsStyle": {
    "width": "calc(100% - 100px)"
  },
  "items": {
    "_deviceManager": {
      "type": "panel",
      "label": "devices",
      "items": {
        "_devMng": {
          "type": "deviceManager",
          "sm": 12,
          "style": {
            "width": "100%",
            "height": "100%",
            "overflow": "hidden"
          }
        }
      },
      "style": {
        "width": "100%",
        "height": "100%",
        "overflow": "hidden"
      },
      "innerStyle": {
        "width": "100%",
        "height": "100%",
        "overflow": "hidden"
      }
    },
    "_tab_Start": {
      "type": "panel",
      "label": "Main Settings",
      "items": {
        "header_Start": {
          "type": "header",
          "text": "Anycubic adapter settings",
          "size": 2
        },
        "_textStart": {
          "type": "staticText",
          "text": "A detailed documentation with explanations and all further information can be found on this GitHub page",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "style": {
            "fontSize": 14,
            "marginTop": 0
          }
        },
        "_documentationLink": {
          "type": "staticLink",
          "label": "click for Documentation",
          "button": true,
          "href": "https://github.com/arteck/ioBroker.anycubic/blob/main/README.md",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "style": {
            "fontSize": 18,
            "marginTop": 0
          }
        },
        "connectionHeader": {
          "type": "header",
          "text": "Select and configure your Anycubic connection",
          "size": 2,
          "newLine": true
        },
        "wsServerIP": {
          "type": "text",
          "label": "Websocket IP-Address",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        },
        "wsServerPort": {
          "type": "number",
          "label": "Websocket Port",
          "newLine": false,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "webUIHeader": {
          "type": "header",
          "text": "Configure your Anycubic WebUi connection",
          "size": 2,
          "newLine": true
        },
        "webUIServer": {
          "type": "text",
          "label": "WebUi IP-Address",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        },
        "webUIPort": {
          "type": "number",
          "label": "WebUi Port",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "newLine": false
        },
        "energyHeader": {
          "type": "header",
          "text": "On/Off state from external device (like plug)",
          "size": 2,
          "newLine": true
        },
        "energy_id": {
          "type": "objectId",
          "label": "Object ID external state",
          "help": "Datapoint of the external state",
          "default": "",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "waitForPrinter": {
          "type": "number",
          "label": "wait x sec. after state is on",
          "help": "wait x sec",
          "default": 50,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "waitForPong": {
          "type": "number",
          "min": 1,
          "max": 100,
          "default": 5,
          "label": "Number of missing pongs until the printer goes offline",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    }
  }
}